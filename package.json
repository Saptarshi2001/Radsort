{
  "name": "radsort",
  "version": "1.0.2",
  "type": "module",
  "description": "radix sort library in typescript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "benchmarks",
    "README.MD"
  ],
  "scripts": {
    "build": "tsc --pretty false",
    "test": "npm run build && node --test tests/*.test.mjs",
    "benchmark": "node benchmarks/benchmark.mjs",
    "benchmark:quick": "node benchmarks/benchmark.mjs --quick"
  },
  "keywords": [
    "radix-sort",
    "sort",
    "typescript",
    "algorithm"
  ],
  "author": "Saptarshi Dutta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saptarshi2001/Radsort.git"
  },
  "bugs": {
    "url": "https://github.com/Saptarshi2001/Radsort/issues"
  },
  "homepage": "https://github.com/Saptarshi2001/Radsort#readme"
}
